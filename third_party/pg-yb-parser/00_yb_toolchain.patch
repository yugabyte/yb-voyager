+# YB-EXT: regenerate proto schema + enum_defs.c / outfuncs_defs.c / readfuncs_defs.c
+# from srcdata/{enum,struct,nodetypes,typedefs}.json. Run after editing srcdata
+# (e.g., to register YB-specific enum values or struct fields).
+#
+# Then runs protoc to refresh pg_query.pb-c.{c,h} from the regenerated proto.
+# In upstream libpg_query, generate_protobuf_and_funcs.rb is a maintainer
+# script not in the Makefile; we wire it in so YB extensions stay reproducible.
+regen_proto:
+	ruby ./scripts/generate_protobuf_and_funcs.rb
+	protoc --proto_path=./protobuf \
+		--c_out=./protobuf \
+		./protobuf/pg_query.proto
+	# protoc-c emits `#include "pg_query.pb-c.h"` in the .pb-c.c, but the header
+	# lives under `protobuf/` once snapshotted into pg_query_go/parser/include/.
+	# Rewrite the include to match libpg_query's expected layout.
+	sed -i 's|#include "pg_query.pb-c.h"|#include "protobuf/pg_query.pb-c.h"|' ./protobuf/pg_query.pb-c.c
+
 .c.o:
 	@$(ECHO) compiling $(<)
 	@$(CC) $(CPPFLAGS) $(CFLAGS) -o $@ -c $<
