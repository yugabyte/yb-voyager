# Toolchain image for regenerating libpg_query sources from PG.
#
# On macOS, the upstream `extract_source.rb` fails because it tries to parse
# Windows-only headers via Apple libclang. libpg_query CI runs on Ubuntu, so
# we mirror that environment for the regen step. The output (src/postgres/
# extracted files, gram.c/scan.c regenerated by bison) is written back to
# the host via a bind mount.
#
# Usage (from third_party/libpg_query/):
#   docker build -f Dockerfile.regen -t libpg_query-regen .
#   docker run --rm -v "$PWD":/work -w /work libpg_query-regen make extract_source
#
# Or via the top-level Makefile target: make pg-yb-parser-regen
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        bison \
        flex \
        curl \
        unzip \
        patch \
        perl \
        pkg-config \
        ruby \
        ruby-dev \
        ruby-bundler \
        libclang-dev \
        clang \
        protobuf-compiler \
        protobuf-c-compiler \
        libprotobuf-c-dev \
        libreadline-dev \
        zlib1g-dev \
        libicu-dev \
        && rm -rf /var/lib/apt/lists/*

# extract_source.rb uses both legacy FFI::Clang::Index.new(positional) API
# and modern FFI::Clang::Types module. The ffi-clang versions that have BOTH
# require Ruby >= 3.1 (which Ubuntu 24.04 ships by default).
RUN gem install ffi-clang -v 0.9.0 --no-document \
    && gem install json --no-document

# libpg_query's extract_source.rb loads libclang via FFI. The shared library
# path differs by host architecture (x86_64 vs aarch64), so resolve at build
# time and symlink to a stable name + set LIBCLANG env var.
RUN set -eux; \
    libclang_path="$(ls /usr/lib/*-linux-gnu/libclang-*.so.1 | head -1)"; \
    test -n "$libclang_path"; \
    ln -sf "$libclang_path" /usr/lib/libclang.so.1; \
    ln -sf "$libclang_path" /usr/lib/libclang.so; \
    echo "$libclang_path" > /etc/libclang_path
ENV LIBCLANG=/usr/lib/libclang.so.1

# extract_source.rb hardcodes a `xcrun --sdk macosx --show-sdk-path` invocation
# for macOS system headers. On Linux we don't need an extra SDK include path;
# stub xcrun so the call succeeds and returns an empty string.
RUN printf '#!/bin/sh\necho ""\n' > /usr/local/bin/xcrun \
    && chmod +x /usr/local/bin/xcrun

WORKDIR /work
